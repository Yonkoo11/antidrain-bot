# Solana RPC endpoint (use a paid RPC for reliability - Helius, QuickNode, etc.)
RPC_URL=https://api.mainnet-beta.solana.com
# WebSocket RPC (usually wss:// version of your RPC)
WS_URL=wss://api.mainnet-beta.solana.com

# Compromised wallet private key (base58 encoded)
COMPROMISED_PRIVATE_KEY=

# Sponsor wallet private key (pays gas fees, base58 encoded)
SPONSOR_PRIVATE_KEY=

# Safe wallet address to receive rescued tokens
SAFE_WALLET_ADDRESS=

# Priority fee in micro-lamports per compute unit (higher = faster, default 100000)
PRIORITY_FEE=500000

# Polling interval in milliseconds (fallback when WebSocket drops, default 5000)
POLL_INTERVAL=5000

# Log file path
LOG_FILE=antidrain.log
